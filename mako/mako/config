# Core Style
font=JetBrainsMono Nerd Font 10
background-color=#1e1e2e
text-color=#cdd6f4
width=300
height=100
margin=10
padding=15
border-size=2
border-radius=8

# This ensures Mako takes charge of the timer regardless of what the app says
ignore-timeout=1
default-timeout=4000

# Colors (Catppuccin Mocha)
border-color=#89dceb
progress-color=over #313244

# CRITERIA FIXES
# ---------------------------------------------------------

# If a notification comes in marked as "high urgency," give it 10s 
# instead of 0 so it doesn't stay on your screen forever.
[urgency=high]
border-color=#f38ba8
default-timeout=10000

# Force notifications that think they are "static" to expire anyway
[expiring=0]
default-timeout=4000

# Surgical strike for Satty: Green border and 2-second timeout
[app-name=Satty]
border-color=#a6e3a1
default-timeout=2000
