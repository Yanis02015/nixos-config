theme = Aizen Dark
# theme = Carbonfox
# theme = Ayu
# theme = Catppuccin Mocha
# theme = Modus Vivendi Tinted
# theme = Dracula
# theme = TokyoNight Night


# font-family = "JetBrainsMono Nerd Font"
# font-family = "IoskeleyMono Nerd Font"
# font-family = "Iosevka Nerd Font"
font-family = "Maple Mono NF"
font-style = Regular
font-size = 12
font-feature = calt
# Center the asterisk: Iosevka's VSAB selector. 8 = hex-mid (centered
# 6-point). Default 1 = penta-high (sits high); 2 = penta-mid (5-point).
font-feature = VSAB=5    

# window
window-padding-y = 1
window-padding-x = 4
resize-overlay = never
background-opacity = 0.85
# background-opacity = 1
window-inherit-working-directory = true

# cursor
cursor-style = "block"
cursor-style-blink = false
# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Slowdown mouse scrolling
mouse-scroll-multiplier = 1
confirm-close-surface = false

window-decoration = false

