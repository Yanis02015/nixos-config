{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/nixos.txt",
    "type": "file",
    // $1 = "Nix" -> terminal foreground, $2 = "OS" -> terminal colour4, the same blue tmux.conf uses
    "color": {
      "1": "default",
      "2": "blue"
    },
    // logo is 5 rows against a 20-row module block -> pad it down to sit centred
    "padding": {
      "top": 7,
      "left": 3
    }
  },
  "display": {
    "separator": " "
  },
  "modules": [
    {
      "type": "custom",
      "format": "┌──────────────────── Hardware ────────────────────┐",
      "outputColor": "blue"
    },
    {
      "type": "cpu",
      "key": "  ",
      "keyColor": "blue"
    },
    {
      "type": "gpu",
      "key": " 󰢮 ",
      "keyColor": "blue"
    },
    {
      "type": "disk",
      "key": " 󰋊 ",
      "keyColor": "blue"
    },
    {
      "type": "memory",
      "key": "  ",
      "keyColor": "blue"
    },
    {
      "type": "display",
      "key": " 󰍹 ",
      "keyColor": "blue"
    },
    {
      "type": "custom",
      "format": "└──────────────────────────────────────────────────┘",
      "outputColor": "blue"
    },
    "break",
    {
      "type": "custom",
      "format": "┌──────────────────── Software ────────────────────┐",
      "outputColor": "cyan"
    },
    {
      "type": "os",
      "key": " 󱄅 ",
      "keyColor": "cyan"
    },
    {
      "type": "wm",
      "key": "  ",
      "keyColor": "cyan"
    },
    {
      "type": "packages",
      "key": " 󰏖 ",
      "keyColor": "cyan"
    },
    {
      "type": "terminal",
      "key": "  ",
      "keyColor": "cyan"
    },
    {
      "type": "terminalfont",
      "key": " 󰛖 ",
      "keyColor": "cyan"
    },
    {
      "type": "custom",
      "format": "└──────────────────────────────────────────────────┘",
      "outputColor": "cyan"
    },
    "break",
    {
      "type": "custom",
      "format": "┌─────────────────── Uptime / Age ─────────────────┐",
      "outputColor": "magenta"
    },
    {
      "type": "uptime",
      "key": " 󰅐  Uptime:",
      "keyColor": "magenta"
    },
    {
      "type": "command",
      "key": " 󰃭  OS Age:",
      "keyColor": "magenta",
      "text": "birth_install=$(stat -c %W /); echo \"$(( ($(date +%s) - birth_install) / 86400 )) days\""
    },
    {
      "type": "custom",
      "format": "└──────────────────────────────────────────────────┘",
      "outputColor": "magenta"
    }
  ]
}
